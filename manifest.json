{
  "manifest_version": 3,
  "name": "AFES Brand Factory Overleaf Helper",
  "version": "1.0.0",
  "description": "Copies or downloads compiled files from an AFES Brand Factory Overleaf project",
  "homepage_url": "https://github.com/dcpurton/afesbrand-overleaf-helper",
  "minimum_chrome_version": "116",
  "permissions": [
    "clipboardWrite",
    "scripting",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://www.overleaf.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AFES Brand Factory Overleaf Helper",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
